@model KoreanLearn.Service.Services.Interfaces.StudentDashboardViewModel
@{ ViewData["Title"] = "學習儀表板"; }

<div class="mb-4">
    <h2><i class="bi bi-mortarboard me-2"></i>我的學習</h2>
    <p class="text-muted">追蹤你的韓語學習進度</p>
</div>

<!-- 學習統計 -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card text-center py-4">
            <div class="kl-stat-number" style="color: var(--kl-primary);">@Model.EnrolledCourses</div>
            <div class="text-muted small mt-1">已選課程</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center py-4">
            <div class="kl-stat-number" style="color: var(--kl-success);">@Model.CompletedLessons</div>
            <div class="text-muted small mt-1">已完成單元</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center py-4">
            <div class="kl-stat-number" style="color: var(--kl-info);">
                @(Model.TotalLessons > 0 ? $"{Model.CompletedLessons * 100 / Model.TotalLessons}%" : "0%")
            </div>
            <div class="text-muted small mt-1">整體進度</div>
        </div>
    </div>
</div>

<!-- 學習工具 -->
<div class="row g-3 mb-4">
    <div class="col-md-6">
        <a asp-area="Learn" asp-controller="Flashcard" asp-action="Index" class="card text-decoration-none">
            <div class="card-body d-flex align-items-center p-3">
                <div class="kl-feature-icon me-3" style="background: rgba(93,176,117,0.1); color: var(--kl-success);">
                    <i class="bi bi-card-text"></i>
                </div>
                <div>
                    <h6 class="mb-0" style="color: var(--kl-text);">字卡練習</h6>
                    <small class="text-muted">透過間隔重複強化記憶</small>
                </div>
                <i class="bi bi-chevron-right ms-auto text-muted"></i>
            </div>
        </a>
    </div>
    <div class="col-md-6">
        <a asp-area="Learn" asp-controller="Pronunciation" asp-action="Index" class="card text-decoration-none">
            <div class="card-body d-flex align-items-center p-3">
                <div class="kl-feature-icon me-3" style="background: rgba(230,183,79,0.1); color: var(--kl-warning);">
                    <i class="bi bi-mic"></i>
                </div>
                <div>
                    <h6 class="mb-0" style="color: var(--kl-text);">發音練習</h6>
                    <small class="text-muted">練習韓語發音並錄音比對</small>
                </div>
                <i class="bi bi-chevron-right ms-auto text-muted"></i>
            </div>
        </a>
    </div>
</div>

<!-- 我的課程 -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-book me-2"></i>我的課程</h4>
    <a asp-area="" asp-controller="Course" asp-action="Index" class="btn btn-sm btn-outline-primary">
        瀏覽更多 <i class="bi bi-arrow-right"></i>
    </a>
</div>

@if (!Model.Courses.Any())
{
    <div class="card text-center py-5">
        <div class="card-body">
            <i class="bi bi-book display-1" style="color: var(--kl-border);"></i>
            <h5 class="mt-3">尚未選課</h5>
            <p class="text-muted">趕快去選一門韓語課程開始學習吧！</p>
            <a asp-area="" asp-controller="Course" asp-action="Index" class="btn btn-primary">
                <i class="bi bi-search me-1"></i>瀏覽課程
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var c in Model.Courses)
        {
            <div class="col-md-4">
                <div class="kl-course-card card h-100">
                    @if (!string.IsNullOrEmpty(c.CoverImageUrl))
                    {
                        <img src="@c.CoverImageUrl" class="card-img-top" style="height:150px; object-fit:cover;" alt="@c.Title" />
                    }
                    else
                    {
                        <div class="card-img-top d-flex align-items-center justify-content-center"
                             style="height:150px; background: linear-gradient(135deg, #EEF1F7 0%, #E1E6EF 100%);">
                            <i class="bi bi-book display-4" style="color: var(--kl-primary); opacity: 0.2;"></i>
                        </div>
                    }
                    <div class="card-body">
                        <h6 class="card-title mb-3">@c.Title</h6>
                        <div class="d-flex justify-content-between small text-muted mb-1">
                            <span>學習進度</span>
                            <span>@c.CompletedLessons / @c.TotalLessons 堂</span>
                        </div>
                        <div class="progress mb-2" style="height:6px;">
                            <div class="progress-bar bg-success" style="width:@c.ProgressPercent%"></div>
                        </div>
                        <div class="text-end">
                            <span class="badge @(c.ProgressPercent >= 100 ? "bg-success" : "bg-info")">
                                @c.ProgressPercent%
                            </span>
                        </div>
                    </div>
                    <div class="card-footer text-center" style="background: transparent; border-top: 1px solid var(--kl-border);">
                        <a asp-area="" asp-controller="Course" asp-action="Detail" asp-route-id="@c.CourseId"
                           class="btn btn-primary btn-sm w-100">繼續學習</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

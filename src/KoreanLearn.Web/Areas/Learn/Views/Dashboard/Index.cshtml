@{ ViewData["Title"] = "我的學習"; }

<h1 class="h3 mb-4">我的學習</h1>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body text-center">
                <i class="bi bi-book display-4 text-primary"></i>
                <h5 class="mt-2">我的課程</h5>
                <p class="text-muted">查看已購買的課程和學習進度</p>
                <a asp-area="Learn" asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-primary">
                    開始學習
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body text-center">
                <i class="bi bi-card-text display-4 text-success"></i>
                <h5 class="mt-2">字卡練習</h5>
                <p class="text-muted">透過間隔重複強化記憶</p>
                <a asp-area="Learn" asp-controller="Flashcard" asp-action="Index" class="btn btn-outline-success">
                    開始練習
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body text-center">
                <i class="bi bi-mic display-4 text-warning"></i>
                <h5 class="mt-2">發音練習</h5>
                <p class="text-muted">練習韓語發音並錄音比對</p>
                <a asp-area="Learn" asp-controller="Pronunciation" asp-action="Index" class="btn btn-outline-warning">
                    開始練習
                </a>
            </div>
        </div>
    </div>
</div>

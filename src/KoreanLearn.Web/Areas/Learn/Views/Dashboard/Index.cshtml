@model KoreanLearn.Service.Services.Interfaces.StudentDashboardViewModel
@{ ViewData["Title"] = "學習儀表板"; }

<h2 class="mb-4"><i class="bi bi-speedometer2 me-2"></i>我的學習</h2>

<!-- Stats -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm text-center py-3">
            <div class="display-5 fw-bold text-primary">@Model.EnrolledCourses</div>
            <div class="text-muted">已選課程</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm text-center py-3">
            <div class="display-5 fw-bold text-success">@Model.CompletedLessons</div>
            <div class="text-muted">已完成單元</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm text-center py-3">
            <div class="display-5 fw-bold text-info">
                @(Model.TotalLessons > 0 ? $"{Model.CompletedLessons * 100 / Model.TotalLessons}%" : "0%")
            </div>
            <div class="text-muted">整體進度</div>
        </div>
    </div>
</div>

<!-- Quick Links -->
<div class="row mb-4">
    <div class="col-md-6">
        <a asp-area="Learn" asp-controller="Flashcard" asp-action="Index" class="card shadow-sm text-decoration-none">
            <div class="card-body d-flex align-items-center">
                <i class="bi bi-card-text display-5 text-success me-3"></i>
                <div><h6 class="mb-0">字卡練習</h6><small class="text-muted">透過間隔重複強化記憶</small></div>
            </div>
        </a>
    </div>
    <div class="col-md-6">
        <a asp-area="Learn" asp-controller="Pronunciation" asp-action="Index" class="card shadow-sm text-decoration-none">
            <div class="card-body d-flex align-items-center">
                <i class="bi bi-mic display-5 text-warning me-3"></i>
                <div><h6 class="mb-0">發音練習</h6><small class="text-muted">練習韓語發音並錄音比對</small></div>
            </div>
        </a>
    </div>
</div>

<!-- My Courses -->
<h4 class="mb-3"><i class="bi bi-book me-2"></i>我的課程</h4>

@if (!Model.Courses.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>您目前沒有選課。
        <a asp-area="" asp-controller="Course" asp-action="Index" class="alert-link">瀏覽課程</a>
    </div>
}
else
{
    <div class="row">
        @foreach (var c in Model.Courses)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100">
                    @if (!string.IsNullOrEmpty(c.CoverImageUrl))
                    {
                        <img src="@c.CoverImageUrl" class="card-img-top" style="height:150px; object-fit:cover;" alt="@c.Title" />
                    }
                    else
                    {
                        <div class="card-img-top bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center" style="height:150px;">
                            <i class="bi bi-book display-4 text-secondary"></i>
                        </div>
                    }
                    <div class="card-body">
                        <h6 class="card-title">@c.Title</h6>
                        <div class="progress mb-2" style="height:8px;">
                            <div class="progress-bar bg-success" style="width:@c.ProgressPercent%"></div>
                        </div>
                        <small class="text-muted">@c.CompletedLessons / @c.TotalLessons 堂 (@c.ProgressPercent%)</small>
                    </div>
                    <div class="card-footer">
                        <a asp-area="" asp-controller="Course" asp-action="Detail" asp-route-id="@c.CourseId"
                           class="btn btn-primary btn-sm w-100">繼續學習</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

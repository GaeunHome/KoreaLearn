@model KoreanLearn.Service.ViewModels.Learn.PdfPlayerViewModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="" asp-controller="Course" asp-action="Detail" asp-route-id="@Model.CourseId">@(Model.CourseTitle ?? "課程")</a></li>
            <li class="breadcrumb-item">@(Model.SectionTitle ?? "章節")</li>
            <li class="breadcrumb-item active">@Model.Title</li>
        </ol>
    </nav>
</div>

<div class="row">
    <div class="col-lg-9">
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-file-pdf display-1 text-danger"></i>
                <h3 class="mt-3">@Model.Title</h3>
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p class="text-muted">@Model.Description</p>
                }

                @if (!string.IsNullOrEmpty(Model.PdfUrl))
                {
                    <div class="mt-4 d-flex justify-content-center gap-3">
                        <a href="@Model.PdfUrl" target="_blank" class="btn btn-primary btn-lg">
                            <i class="bi bi-eye me-2"></i>線上預覽
                        </a>
                        <a href="@Model.PdfUrl" download="@(Model.PdfFileName ?? "document.pdf")" class="btn btn-outline-primary btn-lg">
                            <i class="bi bi-download me-2"></i>下載 PDF
                        </a>
                    </div>
                    <p class="text-muted mt-2"><small>檔案名稱：@(Model.PdfFileName ?? "document.pdf")</small></p>
                }
                else
                {
                    <div class="alert alert-info mt-3">
                        <i class="bi bi-info-circle me-2"></i>此單元尚無 PDF 檔案。
                    </div>
                }
            </div>
        </div>

        <!-- Bottom Navigation -->
        <div class="d-flex justify-content-between align-items-center mt-4">
            @if (Model.PreviousLessonId.HasValue)
            {
                <a asp-area="Learn" asp-controller="Lesson" asp-action="Pdf" asp-route-id="@Model.PreviousLessonId"
                   class="btn btn-outline-primary">
                    <i class="bi bi-arrow-left me-1"></i>上一個單元
                </a>
            }
            else
            {
                <div></div>
            }

            @if (!Model.IsCompleted)
            {
                <button class="btn btn-success" id="btnComplete" onclick="markComplete()">
                    <i class="bi bi-check-circle me-1"></i>完成閱讀
                </button>
            }
            else
            {
                <span class="badge bg-success fs-6" id="completeBadge">
                    <i class="bi bi-check-circle-fill me-1"></i>已完成
                </span>
            }

            @if (Model.NextLessonId.HasValue)
            {
                <a asp-area="Learn" asp-controller="Lesson" asp-action="Pdf" asp-route-id="@Model.NextLessonId"
                   class="btn btn-primary">
                    下一個單元<i class="bi bi-arrow-right ms-1"></i>
                </a>
            }
            else
            {
                <div></div>
            }
        </div>
    </div>

    <!-- Sidebar -->
    <div class="col-lg-3">
        <div class="card shadow-sm">
            <div class="card-header bg-light">
                <h6 class="mb-0"><i class="bi bi-list-ul me-1"></i>單元導航</h6>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    @if (Model.PreviousLessonId.HasValue)
                    {
                        <a asp-area="Learn" asp-controller="Lesson" asp-action="Pdf" asp-route-id="@Model.PreviousLessonId"
                           class="list-group-item list-group-item-action">
                            <i class="bi bi-arrow-left me-1"></i>上一個單元
                        </a>
                    }
                    <div class="list-group-item active">
                        <i class="bi bi-file-pdf-fill me-1"></i>@Model.Title
                    </div>
                    @if (Model.NextLessonId.HasValue)
                    {
                        <a asp-area="Learn" asp-controller="Lesson" asp-action="Pdf" asp-route-id="@Model.NextLessonId"
                           class="list-group-item list-group-item-action">
                            下一個單元<i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    }
                </div>
            </div>
            <div class="card-footer text-center">
                <a asp-area="" asp-controller="Course" asp-action="Detail" asp-route-id="@Model.CourseId"
                   class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>返回課程
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.markComplete = function () {
            fetch('@Url.Action("Complete", "Lesson", new { area = "Learn" })/@Model.LessonId', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        const btn = document.getElementById('btnComplete');
                        if (btn) btn.outerHTML = '<span class="badge bg-success fs-6"><i class="bi bi-check-circle-fill me-1"></i>已完成</span>';
                    }
                });
        };
    </script>
}

@model KoreanLearn.Service.ViewModels.Learn.VideoPlayerViewModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="" asp-controller="Course" asp-action="Detail" asp-route-id="@Model.CourseId">@(Model.CourseTitle ?? "課程")</a></li>
            <li class="breadcrumb-item">@(Model.SectionTitle ?? "章節")</li>
            <li class="breadcrumb-item active">@Model.Title</li>
        </ol>
    </nav>
</div>

<div class="row">
    <div class="col-lg-9">
        <!-- Video Player -->
        <div class="card shadow-sm mb-3">
            <div class="card-body p-0">
                @if (!string.IsNullOrEmpty(Model.VideoUrl))
                {
                    <video id="videoPlayer" class="w-100" controls preload="metadata"
                           style="max-height: 540px; background: #000;">
                        <source src="@Model.VideoUrl" type="video/mp4" />
                        您的瀏覽器不支援 HTML5 影片播放。
                    </video>
                }
                else
                {
                    <div class="text-center py-5 bg-dark text-white">
                        <i class="bi bi-exclamation-triangle display-4"></i>
                        <p class="mt-2">此單元尚無影片內容</p>
                    </div>
                }
            </div>
        </div>

        <!-- Lesson Info -->
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h4 class="mb-1">@Model.Title</h4>
                        @if (Model.VideoDurationSeconds.HasValue)
                        {
                            var mins = Model.VideoDurationSeconds.Value / 60;
                            var secs = Model.VideoDurationSeconds.Value % 60;
                            <span class="text-muted">
                                <i class="bi bi-clock me-1"></i>@mins:@secs.ToString("D2")
                            </span>
                        }
                    </div>
                    <div>
                        @if (Model.IsCompleted)
                        {
                            <span class="badge bg-success fs-6" id="completeBadge">
                                <i class="bi bi-check-circle-fill me-1"></i>已完成
                            </span>
                        }
                        else
                        {
                            <button class="btn btn-outline-success btn-sm" id="btnComplete"
                                    onclick="markComplete()">
                                <i class="bi bi-check-circle me-1"></i>標記完成
                            </button>
                        }
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <hr />
                    <p class="text-muted mb-0">@Model.Description</p>
                }
            </div>
        </div>
    </div>

    <!-- Sidebar: Navigation -->
    <div class="col-lg-3">
        <div class="card shadow-sm">
            <div class="card-header bg-light">
                <h6 class="mb-0"><i class="bi bi-list-ul me-1"></i>單元導航</h6>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    @if (Model.PreviousLessonId.HasValue)
                    {
                        <a asp-area="Learn" asp-controller="Lesson" asp-action="Video" asp-route-id="@Model.PreviousLessonId"
                           class="list-group-item list-group-item-action">
                            <i class="bi bi-arrow-left me-1"></i>上一個單元
                        </a>
                    }
                    <div class="list-group-item active">
                        <i class="bi bi-play-circle-fill me-1"></i>@Model.Title
                    </div>
                    @if (Model.NextLessonId.HasValue)
                    {
                        <a asp-area="Learn" asp-controller="Lesson" asp-action="Video" asp-route-id="@Model.NextLessonId"
                           class="list-group-item list-group-item-action">
                            下一個單元<i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    }
                </div>
            </div>
            <div class="card-footer text-center">
                <a asp-area="" asp-controller="Course" asp-action="Detail" asp-route-id="@Model.CourseId"
                   class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>返回課程
                </a>
            </div>
        </div>

        <!-- Progress indicator -->
        <div class="card shadow-sm mt-3">
            <div class="card-body text-center">
                <h6 class="text-muted">播放進度</h6>
                <div id="progressDisplay" class="fs-4 fw-bold text-primary">
                    @{ var pm = Model.VideoProgressSeconds / 60; var ps = Model.VideoProgressSeconds % 60; }
                    @pm:@ps.ToString("D2")
                </div>
                <small class="text-muted" id="progressStatus">自動儲存中...</small>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const video = document.getElementById('videoPlayer');
            if (!video) return;

            const lessonId = @Model.LessonId;
            const startProgress = @Model.VideoProgressSeconds;
            let lastSaved = startProgress;
            let saveTimer = null;

            // Resume from saved progress
            video.addEventListener('loadedmetadata', function () {
                if (startProgress > 0 && startProgress < video.duration) {
                    video.currentTime = startProgress;
                }
            });

            // Auto-save progress every 10 seconds while playing
            video.addEventListener('timeupdate', function () {
                const current = Math.floor(video.currentTime);
                updateProgressDisplay(current);

                if (Math.abs(current - lastSaved) >= 10) {
                    lastSaved = current;
                    saveProgress(current);
                }
            });

            // Save on pause
            video.addEventListener('pause', function () {
                saveProgress(Math.floor(video.currentTime));
            });

            // Auto-complete when video ends
            video.addEventListener('ended', function () {
                saveProgress(Math.floor(video.duration));
                markComplete();
            });

            function saveProgress(seconds) {
                fetch('@Url.Action("SaveProgress", "Lesson", new { area = "Learn" })', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: JSON.stringify({ lessonId: lessonId, progressSeconds: seconds })
                })
                    .then(r => r.json())
                    .then(data => {
                        if (data.success) {
                            document.getElementById('progressStatus').textContent = '已儲存';
                            setTimeout(() => {
                                document.getElementById('progressStatus').textContent = '自動儲存中...';
                            }, 2000);
                        }
                    })
                    .catch(() => {
                        document.getElementById('progressStatus').textContent = '儲存失敗';
                    });
            }

            function updateProgressDisplay(seconds) {
                const m = Math.floor(seconds / 60);
                const s = seconds % 60;
                document.getElementById('progressDisplay').textContent =
                    m + ':' + s.toString().padStart(2, '0');
            }

            // Expose markComplete globally
            window.markComplete = function () {
                fetch('@Url.Action("Complete", "Lesson", new { area = "Learn" })' + '/' + lessonId, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    }
                })
                    .then(r => r.json())
                    .then(data => {
                        if (data.success) {
                            const btn = document.getElementById('btnComplete');
                            if (btn) {
                                btn.outerHTML = '<span class="badge bg-success fs-6" id="completeBadge"><i class="bi bi-check-circle-fill me-1"></i>已完成</span>';
                            }
                        }
                    });
            };
        })();
    </script>
}

@model IReadOnlyList<KoreanLearn.Service.ViewModels.Learn.LessonAttachmentViewModel>

@if (Model.Any())
{
    <div class="card shadow-sm mt-4">
        <div class="card-header bg-light">
            <h6 class="mb-0"><i class="bi bi-paperclip me-1"></i>附件下載（@Model.Count 個檔案）</h6>
        </div>
        <div class="list-group list-group-flush">
            @foreach (var att in Model)
            {
                <a href="@att.FileUrl" download="@att.FileName"
                   class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                    <span>
                        <i class="bi bi-file-earmark-arrow-down me-2"></i>@att.FileName
                    </span>
                    <span class="badge bg-light text-dark">@att.FileSizeDisplay</span>
                </a>
            }
        </div>
    </div>
}

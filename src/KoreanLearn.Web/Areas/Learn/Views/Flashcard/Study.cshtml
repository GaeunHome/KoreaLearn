@model KoreanLearn.Service.ViewModels.Learn.FlashcardStudyViewModel
@{ ViewData["Title"] = $"學習 - {Model.DeckTitle}"; }

<div class="mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Learn" asp-controller="Flashcard" asp-action="Index">字卡練習</a></li>
            <li class="breadcrumb-item active">@Model.DeckTitle</li>
        </ol>
    </nav>
</div>

@if (!Model.Cards.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-check-circle-fill display-1 text-success"></i>
        <h3 class="mt-3">今日學習完成！</h3>
        <p class="text-muted">沒有待複習的字卡了</p>
        <a asp-area="Learn" asp-controller="Flashcard" asp-action="Index" class="btn btn-primary">
            <i class="bi bi-arrow-left me-1"></i>返回牌組列表
        </a>
    </div>
}
else
{
    <div class="text-center mb-3">
        <span class="badge bg-info fs-6 me-2">共 @Model.Cards.Count 張</span>
        <span class="text-muted" id="progressText">第 1 / @Model.Cards.Count 張</span>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <!-- Flashcard -->
            <div id="flashcard" class="card shadow-lg" style="min-height: 300px; cursor: pointer; perspective: 1000px;"
                 onclick="flipCard()">
                <div id="cardInner" style="position: relative; width: 100%; height: 100%; transition: transform 0.6s; transform-style: preserve-3d;">
                    <!-- Front (Korean) -->
                    <div id="cardFront" class="card-body d-flex flex-column align-items-center justify-content-center text-center"
                         style="min-height: 300px; backface-visibility: hidden;">
                        <h1 class="display-3 mb-3" id="koreanText"></h1>
                        <p class="text-muted" id="romanText"></p>
                        <small class="text-muted mt-3"><i class="bi bi-hand-index me-1"></i>點擊翻轉</small>
                    </div>
                    <!-- Back (Chinese) -->
                    <div id="cardBack" class="card-body d-flex flex-column align-items-center justify-content-center text-center"
                         style="min-height: 300px; backface-visibility: hidden; position: absolute; top: 0; left: 0; right: 0; transform: rotateY(180deg); display: none;">
                        <h2 class="display-4 mb-3" id="chineseText"></h2>
                        <p class="text-muted" id="exampleText"></p>
                    </div>
                </div>
            </div>

            <!-- Rating buttons (hidden until flipped) -->
            <div id="ratingButtons" class="mt-4 text-center" style="display: none;">
                <p class="text-muted mb-2">你記得這張字卡嗎？</p>
                <div class="d-flex justify-content-center gap-2">
                    <button class="btn btn-danger" onclick="rateCard(1)">
                        <i class="bi bi-emoji-frown me-1"></i>不記得
                    </button>
                    <button class="btn btn-warning" onclick="rateCard(3)">
                        <i class="bi bi-emoji-neutral me-1"></i>有點印象
                    </button>
                    <button class="btn btn-success" onclick="rateCard(4)">
                        <i class="bi bi-emoji-smile me-1"></i>記得
                    </button>
                    <button class="btn btn-primary" onclick="rateCard(5)">
                        <i class="bi bi-emoji-laughing me-1"></i>很熟
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@section Styles {
    <style>
        #cardInner.flipped { transform: rotateY(180deg); }
        #cardInner.flipped #cardFront { display: none; }
        #cardInner.flipped #cardBack { display: flex !important; }
    </style>
}

@section Scripts {
    <script>
        var cards = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Cards));
        var currentIndex = 0;
        var isFlipped = false;

        function showCard() {
            if (currentIndex >= cards.length) {
                document.getElementById('flashcard').innerHTML =
                    '<div class="card-body text-center py-5"><i class="bi bi-check-circle-fill display-1 text-success"></i><h3 class="mt-3">學習完成！</h3></div>';
                document.getElementById('ratingButtons').style.display = 'none';
                document.getElementById('progressText').textContent = '完成！';
                return;
            }
            var card = cards[currentIndex];
            document.getElementById('koreanText').textContent = card.korean;
            document.getElementById('romanText').textContent = card.romanization || '';
            document.getElementById('chineseText').textContent = card.chinese;
            document.getElementById('exampleText').textContent = card.exampleSentence || '';
            document.getElementById('cardInner').classList.remove('flipped');
            document.getElementById('ratingButtons').style.display = 'none';
            document.getElementById('progressText').textContent = '第 ' + (currentIndex + 1) + ' / ' + cards.length + ' 張';
            isFlipped = false;
        }

        function flipCard() {
            if (isFlipped) return;
            document.getElementById('cardInner').classList.add('flipped');
            document.getElementById('ratingButtons').style.display = 'block';
            isFlipped = true;
        }

        function rateCard(quality) {
            var card = cards[currentIndex];
            fetch('@Url.Action("Review", "Flashcard", new { area = "Learn" })', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ cardId: card.cardId, quality: quality })
            }).then(function () {
                currentIndex++;
                showCard();
            });
        }

        showCard();
    </script>
}

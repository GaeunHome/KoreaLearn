@model ForgotPasswordViewModel
@{ ViewData["Title"] = "忘記密碼"; }

<div class="kl-auth-wrapper">
    <div class="card kl-auth-card">
        <div class="kl-auth-header">
            <h3><i class="bi bi-envelope me-2"></i>忘記密碼</h3>
            <p>輸入您的電子信箱以重設密碼</p>
        </div>
        <div class="card-body">
            @if (Model.ShowConfirmation)
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-1"></i>
                    若此電子信箱已註冊，您將收到密碼重設連結。
                </div>
                @if (Model.ResetToken is not null)
                {
                    <div class="alert alert-secondary small">
                        <strong>開發模式</strong>：正式環境中此 Token 會透過 Email 寄送。<br />
                        <a asp-action="ResetPassword" asp-controller="Account" asp-area="Identity"
                           asp-route-email="@Model.ResetEmail"
                           asp-route-token="@Model.ResetToken">
                            點此重設密碼
                        </a>
                    </div>
                }
                <div class="text-center mt-3">
                    <a asp-action="Login" asp-controller="Account" asp-area="Identity" class="text-decoration-none">返回登入</a>
                </div>
            }
            else
            {
                <form asp-action="ForgotPassword" asp-controller="Account" asp-area="Identity" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">發送重設連結</button>
                </form>
                <div class="text-center mt-3">
                    <a asp-action="Login" asp-controller="Account" asp-area="Identity" class="text-decoration-none">
                        <i class="bi bi-arrow-left me-1"></i>返回登入
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

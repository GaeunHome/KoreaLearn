@{ ViewData["Title"] = "Email 驗證"; }

<div class="kl-auth-wrapper">
    <div class="card kl-auth-card" style="max-width: 520px;">
        <div class="kl-auth-header">
            @if (ViewBag.Confirmed == true)
            {
                <i class="bi bi-check-circle text-success" style="font-size: 3rem;"></i>
                <h3 class="mt-2">Email 驗證成功！</h3>
                <p>您的電子信箱已驗證完成，帳號已自動登入。</p>
            }
            else
            {
                <i class="bi bi-x-circle text-danger" style="font-size: 3rem;"></i>
                <h3 class="mt-2">驗證失敗</h3>
                <p class="text-danger">@ViewBag.ErrorMessage</p>
            }
        </div>
        <div class="card-body text-center">
            @if (ViewBag.Confirmed == true)
            {
                <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-primary">
                    <i class="bi bi-house me-1"></i>前往首頁
                </a>
            }
            else
            {
                <a asp-action="Login" asp-controller="Account" asp-area="Identity" class="btn btn-primary">
                    前往登入
                </a>
            }
        </div>
    </div>
</div>

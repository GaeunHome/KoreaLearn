@{
    ViewData["Title"] = "註冊成功 — 請驗證 Email";
    var email = ViewBag.Email as string;
}

<div class="kl-auth-wrapper">
    <div class="card kl-auth-card" style="max-width: 520px;">
        <div class="kl-auth-header">
            <i class="bi bi-envelope-check" style="font-size: 3rem; color: var(--kl-success);"></i>
            <h3 class="mt-2">請驗證您的電子信箱</h3>
            <p>我們已寄送驗證信至</p>
        </div>
        <div class="card-body text-center">
            <div class="alert alert-light mb-4">
                <strong style="font-size: 1.1rem;">@email</strong>
            </div>

            <p class="text-muted small mb-4">
                請前往信箱點擊驗證連結以啟用帳號。<br />
                驗證成功後將自動登入系統。
            </p>

            <div class="alert alert-info small text-start">
                <i class="bi bi-info-circle me-1"></i>
                <strong>沒收到信？</strong>
                <ul class="mb-0 mt-1">
                    <li>請檢查垃圾郵件或促銷分類</li>
                    <li>確認信箱地址是否正確</li>
                    <li>或點擊下方按鈕重新寄送</li>
                </ul>
            </div>

            <form asp-action="ResendConfirmationEmail" asp-controller="Account" asp-area="Identity" method="post" class="mt-3">
                <input type="hidden" name="email" value="@email" />
                <button type="submit" class="btn btn-outline-primary">
                    <i class="bi bi-arrow-clockwise me-1"></i>重新寄送驗證信
                </button>
            </form>

            <hr class="my-4" />

            <a asp-action="Login" asp-controller="Account" asp-area="Identity" class="text-decoration-none">
                <i class="bi bi-arrow-left me-1"></i>返回登入頁面
            </a>
        </div>
    </div>
</div>

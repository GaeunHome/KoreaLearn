@model SetupAuthenticatorViewModel
@{
    ViewData["Title"] = "設定驗證器 App";
}

<div class="kl-settings-page">
    <div class="kl-settings-nav">
        <a class="btn btn-outline-secondary btn-sm" asp-action="Profile" asp-controller="Account" asp-area="Identity">
            <i class="bi bi-person me-1"></i>個人資料
        </a>
        <a class="btn btn-outline-secondary btn-sm" asp-action="ChangePassword" asp-controller="Account" asp-area="Identity">
            <i class="bi bi-key me-1"></i>變更密碼
        </a>
        <a class="btn btn-primary btn-sm" asp-action="TwoFactorAuthentication" asp-controller="Account" asp-area="Identity">
            <i class="bi bi-shield-check me-1"></i>兩步驟驗證
        </a>
    </div>

    <div class="card kl-settings-card">
        <div class="card-body">
            <div class="kl-settings-header">
                <i class="bi bi-qr-code"></i>
                <div>
                    <h4>設定驗證器 App</h4>
                    <p>使用驗證器 App 掃描 QR Code 以完成設定</p>
                </div>
            </div>

            <div class="row">
                <div class="col-md-7">
                    <!-- 步驟一 -->
                    <div class="mb-4">
                        <h6><span class="badge bg-primary me-1">1</span> 下載驗證器 App</h6>
                        <p class="text-muted small mb-0">請在手機安裝以下任一驗證器 App：</p>
                        <ul class="small text-muted mt-1 mb-0">
                            <li>Google Authenticator（<a href="https://play.google.com/store/apps/details?id=com.google.android.apps.authenticator2" target="_blank" rel="noopener">Android</a> / <a href="https://apps.apple.com/app/google-authenticator/id388497605" target="_blank" rel="noopener">iOS</a>）</li>
                            <li>Microsoft Authenticator（<a href="https://play.google.com/store/apps/details?id=com.azure.authenticator" target="_blank" rel="noopener">Android</a> / <a href="https://apps.apple.com/app/microsoft-authenticator/id983156458" target="_blank" rel="noopener">iOS</a>）</li>
                        </ul>
                    </div>

                    <!-- 步驟二 -->
                    <div class="mb-4">
                        <h6><span class="badge bg-primary me-1">2</span> 掃描 QR Code</h6>
                        <p class="text-muted small mb-1">無法掃描？請手動輸入以下金鑰：</p>
                        <div class="bg-light p-2 rounded">
                            <code style="font-size: 0.85rem; letter-spacing: 2px;">@Model.SharedKey</code>
                        </div>
                    </div>

                    <!-- 步驟三 -->
                    <div class="mb-3">
                        <h6><span class="badge bg-primary me-1">3</span> 輸入驗證碼</h6>
                        <p class="text-muted small">開啟驗證器 App，輸入顯示的 6 位數驗證碼：</p>
                    </div>

                    <form asp-action="SetupAuthenticator" asp-controller="Account" asp-area="Identity" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <div class="mb-3" style="max-width: 280px;">
                            <input asp-for="VerificationCode" class="form-control text-center"
                                   style="font-size: 1.5rem; letter-spacing: 0.5em;" maxlength="6"
                                   placeholder="000000" autofocus />
                            <span asp-validation-for="VerificationCode" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i>驗證並啟用
                        </button>
                        <a asp-action="TwoFactorAuthentication" asp-controller="Account" asp-area="Identity"
                           class="btn btn-outline-secondary ms-2">取消</a>
                    </form>
                </div>

                <!-- QR Code 右側 -->
                <div class="col-md-5 text-center d-flex align-items-start justify-content-center pt-4">
                    <div class="p-3 bg-white rounded" style="box-shadow: 0 2px 12px rgba(0,0,0,0.08);">
                        <img src="data:image/png;base64,@Model.QrCodeBase64"
                             alt="QR Code" style="image-rendering: pixelated; width: 200px; height: 200px;" />
                        <p class="text-muted small mt-2 mb-0">掃描此 QR Code</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

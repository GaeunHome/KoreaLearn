@model ChangePasswordViewModel
@{ ViewData["Title"] = "變更密碼"; }

<div class="kl-settings-page">
    <div class="kl-settings-nav">
        <a class="btn btn-outline-secondary btn-sm" asp-action="Profile" asp-controller="Account" asp-area="Identity">
            <i class="bi bi-person me-1"></i>個人資料
        </a>
        <a class="btn btn-primary btn-sm" asp-action="ChangePassword" asp-controller="Account" asp-area="Identity">
            <i class="bi bi-key me-1"></i>變更密碼
        </a>
        <a class="btn btn-outline-secondary btn-sm" asp-action="TwoFactorAuthentication" asp-controller="Account" asp-area="Identity">
            <i class="bi bi-shield-check me-1"></i>兩步驟驗證
        </a>
    </div>

    <div class="card kl-settings-card">
        <div class="card-body">
            <div class="kl-settings-header">
                <i class="bi bi-key"></i>
                <div>
                    <h4>變更密碼</h4>
                    <p>請輸入目前密碼與新密碼</p>
                </div>
            </div>

            <form asp-action="ChangePassword" asp-controller="Account" asp-area="Identity" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="row">
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label asp-for="CurrentPassword" class="form-label">目前密碼 <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-lock"></i></span>
                                <input asp-for="CurrentPassword" class="form-control" autocomplete="current-password" />
                                <button type="button" class="btn btn-outline-secondary kl-toggle-pw" tabindex="-1">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label">新密碼 <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                                <input asp-for="NewPassword" class="form-control" autocomplete="new-password" />
                                <button type="button" class="btn btn-outline-secondary kl-toggle-pw" tabindex="-1">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label">確認新密碼 <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                                <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                                <button type="button" class="btn btn-outline-secondary kl-toggle-pw" tabindex="-1">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-4 d-none d-md-block">
                        <div class="alert alert-light small">
                            <strong class="d-block mb-2"><i class="bi bi-info-circle me-1"></i>密碼規則</strong>
                            <ul class="list-unstyled mb-0" style="font-size: 0.82rem;">
                                <li><i class="bi bi-check2 text-success me-1"></i>至少 6 個字元</li>
                                <li><i class="bi bi-check2 text-success me-1"></i>包含數字</li>
                                <li><i class="bi bi-check2 text-success me-1"></i>不可與近 5 次密碼相同</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end mt-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-check-lg me-1"></i>變更密碼
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

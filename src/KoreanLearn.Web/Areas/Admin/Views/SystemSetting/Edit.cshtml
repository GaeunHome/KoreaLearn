@model KoreanLearn.Service.ViewModels.Admin.SystemSetting.SystemSettingFormViewModel
@{
    ViewData["Title"] = "編輯系統參數";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-pencil-square me-2"></i>編輯系統參數</h2>
    <a asp-area="Admin" asp-controller="SystemSetting" asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>返回列表
    </a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-area="Admin" asp-controller="SystemSetting" asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Key" class="form-label">參數鍵</label>
                <input asp-for="Key" class="form-control" readonly />
            </div>

            <div class="mb-3">
                <label asp-for="Value" class="form-label">參數值 <span class="text-danger">*</span></label>
                <textarea asp-for="Value" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Value" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">說明</label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Group" class="form-label">分組</label>
                <input asp-for="Group" class="form-control" placeholder="例如：網站設定" />
                <span asp-validation-for="Group" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>儲存變更
            </button>
        </form>
    </div>
</div>

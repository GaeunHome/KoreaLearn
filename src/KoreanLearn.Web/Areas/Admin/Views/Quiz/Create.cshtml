@model KoreanLearn.Service.ViewModels.Admin.Quiz.QuizFormViewModel
@{
    ViewData["Title"] = "建立測驗";
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Course" asp-action="Index">課程管理</a></li>
            @if (Model.CourseId.HasValue)
            {
                <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Course" asp-action="Detail" asp-route-id="@Model.CourseId">@(Model.CourseTitle ?? "課程")</a></li>
            }
            <li class="breadcrumb-item active">建立測驗</li>
        </ol>
    </nav>
    <h2><i class="bi bi-question-circle me-2"></i>建立測驗 — @(Model.LessonTitle ?? "單元")</h2>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-area="Admin" asp-controller="Quiz" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="LessonId" type="hidden" />
                    <input asp-for="LessonTitle" type="hidden" />
                    <input asp-for="CourseTitle" type="hidden" />
                    <input asp-for="CourseId" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:none;"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">測驗標題 <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control" placeholder="請輸入測驗標題" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">說明</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="測驗說明"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="PassingScore" class="form-label">及格分數 <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="PassingScore" class="form-control" type="number" min="0" max="100" />
                                <span class="input-group-text">分</span>
                            </div>
                            <span asp-validation-for="PassingScore" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="TimeLimitMinutes" class="form-label">時間限制</label>
                            <div class="input-group">
                                <input asp-for="TimeLimitMinutes" class="form-control" type="number" min="0" max="180" />
                                <span class="input-group-text">分鐘</span>
                            </div>
                            <small class="text-muted">0 表示無限制</small>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary" onclick="this.disabled=true;this.form.submit();">
                            <i class="bi bi-check-lg me-1"></i>建立測驗
                        </button>
                        @if (Model.CourseId.HasValue)
                        {
                            <a asp-area="Admin" asp-controller="Course" asp-action="Detail" asp-route-id="@Model.CourseId" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i>返回課程
                            </a>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

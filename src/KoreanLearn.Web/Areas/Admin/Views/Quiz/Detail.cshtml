@model KoreanLearn.Service.ViewModels.Admin.Quiz.QuizDetailViewModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Course" asp-action="Index">課程管理</a></li>
            @if (Model.CourseId.HasValue)
            {
                <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Course" asp-action="Detail" asp-route-id="@Model.CourseId">@(Model.CourseTitle ?? "課程")</a></li>
            }
            <li class="breadcrumb-item active">@Model.Title</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-start">
        <div>
            <h2><i class="bi bi-question-circle me-2"></i>@Model.Title</h2>
            <div class="d-flex gap-3 text-muted mt-1">
                <span><i class="bi bi-check-circle me-1"></i>及格：@Model.PassingScore 分</span>
                <span><i class="bi bi-clock me-1"></i>@(Model.TimeLimitMinutes > 0 ? $"{Model.TimeLimitMinutes} 分鐘" : "無限制")</span>
                <span><i class="bi bi-star me-1"></i>總分：@Model.TotalPoints 分</span>
                <span><i class="bi bi-list-ol me-1"></i>@Model.Questions.Count 題</span>
            </div>
        </div>
        <div class="d-flex gap-2">
            <a asp-area="Admin" asp-controller="Quiz" asp-action="Edit" asp-route-id="@Model.Id"
               class="btn btn-outline-primary">
                <i class="bi bi-pencil me-1"></i>編輯測驗
            </a>
            <a asp-area="Admin" asp-controller="Quiz" asp-action="AddQuestion"
               asp-route-quizId="@Model.Id" asp-route-courseId="@Model.CourseId"
               class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i>新增題目
            </a>
        </div>
    </div>
</div>

@if (!Model.Questions.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>尚無題目，請點擊「新增題目」開始出題。
    </div>
}
else
{
    @for (var i = 0; i < Model.Questions.Count; i++)
    {
        var q = Model.Questions[i];
        <div class="card shadow-sm mb-3">
            <div class="card-header d-flex justify-content-between align-items-center bg-light">
                <div>
                    <span class="fw-bold">第 @(i + 1) 題</span>
                    <span class="badge bg-secondary ms-2">@q.Type</span>
                    <span class="badge bg-info ms-1">@q.Points 分</span>
                </div>
                <div class="d-flex gap-2">
                    <a asp-area="Admin" asp-controller="Quiz" asp-action="EditQuestion" asp-route-id="@q.Id"
                       class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <form asp-area="Admin" asp-controller="Quiz" asp-action="DeleteQuestion"
                          asp-route-id="@q.Id" asp-route-quizId="@Model.Id"
                          method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                data-confirm="確定要刪除此題目嗎？刪除後無法復原。">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>
                </div>
            </div>
            <div class="card-body">
                <p class="mb-2 fw-semibold">@q.Content</p>
                @if (q.Options.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var opt in q.Options)
                        {
                            <li class="list-group-item d-flex align-items-center @(opt.IsCorrect ? "list-group-item-success" : "")">
                                @if (opt.IsCorrect)
                                {
                                    <i class="bi bi-check-circle-fill text-success me-2"></i>
                                }
                                else
                                {
                                    <i class="bi bi-circle me-2 text-muted"></i>
                                }
                                @opt.Content
                            </li>
                        }
                    </ul>
                }
                @if (!string.IsNullOrEmpty(q.CorrectAnswer))
                {
                    <div class="mt-2">
                        <span class="text-muted">正確答案：</span>
                        <code>@q.CorrectAnswer</code>
                    </div>
                }
            </div>
        </div>
    }
}

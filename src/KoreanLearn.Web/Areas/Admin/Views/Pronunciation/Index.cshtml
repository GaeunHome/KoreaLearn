@model KoreanLearn.Library.Helpers.PagedResult<KoreanLearn.Service.ViewModels.Admin.Pronunciation.PronunciationListViewModel>
@{ ViewData["Title"] = "發音練習管理"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-mic me-2"></i>發音練習管理</h2>
    <a asp-area="Admin" asp-controller="Pronunciation" asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>新增
    </a>
</div>

@if (!Model.Items.Any())
{
    <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>目前沒有發音練習。</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr><th>#</th><th>韓文</th><th>羅馬拼音</th><th>中文</th><th>音檔</th><th style="width:150px">操作</th></tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Items)
                {
                    <tr>
                        <td class="text-muted">@p.Id</td>
                        <td class="fw-bold fs-5">@p.Korean</td>
                        <td class="text-muted">@(p.Romanization ?? "—")</td>
                        <td>@(p.Chinese ?? "—")</td>
                        <td>
                            @if (!string.IsNullOrEmpty(p.StandardAudioUrl))
                            {
                                <audio controls preload="none" style="height:30px;"><source src="@p.StandardAudioUrl" /></audio>
                            }
                        </td>
                        <td>
                            <a asp-area="Admin" asp-controller="Pronunciation" asp-action="Edit" asp-route-id="@p.Id"
                               class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i></a>
                            <form asp-area="Admin" asp-controller="Pronunciation" asp-action="Delete" asp-route-id="@p.Id"
                                  method="post" class="d-inline" onsubmit="return confirm('確定刪除？');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@{ ViewData["Title"] = "儀表板"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3">儀表板</h1>
</div>

<div class="row g-4">
    <div class="col-md-3">
        <div class="card text-bg-primary shadow-sm">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-book me-2"></i>課程</h5>
                <p class="card-text display-6">--</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-bg-success shadow-sm">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-people me-2"></i>用戶</h5>
                <p class="card-text display-6">--</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-bg-warning shadow-sm">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-cart me-2"></i>訂單</h5>
                <p class="card-text display-6">--</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-bg-info shadow-sm">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-currency-dollar me-2"></i>收入</h5>
                <p class="card-text display-6">--</p>
            </div>
        </div>
    </div>
</div>

<div class="mt-4">
    <p class="text-muted">詳細統計數據將在 P3-07 實作後顯示。</p>
</div>

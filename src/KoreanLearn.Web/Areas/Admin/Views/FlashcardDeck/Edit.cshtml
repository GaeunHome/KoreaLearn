@model KoreanLearn.Service.ViewModels.Admin.Flashcard.DeckFormViewModel
@{ ViewData["Title"] = "編輯牌組"; }

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="FlashcardDeck" asp-action="Index">字卡管理</a></li>
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="FlashcardDeck" asp-action="Detail" asp-route-id="@Model.Id">@Model.Title</a></li>
            <li class="breadcrumb-item active">編輯</li>
        </ol>
    </nav>
    <h2><i class="bi bi-pencil me-2"></i>編輯牌組</h2>
</div>

<div class="row"><div class="col-lg-8">
    <div class="card shadow-sm"><div class="card-body">
        <form asp-area="Admin" asp-controller="FlashcardDeck" asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:none;"></div>
            <div class="mb-3">
                <label asp-for="Title" class="form-label">牌組標題 <span class="text-danger">*</span></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label">說明</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>儲存變更</button>
                <a asp-area="Admin" asp-controller="FlashcardDeck" asp-action="Detail" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>返回</a>
            </div>
        </form>
    </div></div>
</div></div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }

@model KoreanLearn.Library.Helpers.PagedResult<KoreanLearn.Service.ViewModels.Admin.Flashcard.DeckListViewModel>
@{
    ViewData["Title"] = "字卡管理";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-card-text me-2"></i>字卡管理</h2>
    <a asp-area="Admin" asp-controller="FlashcardDeck" asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>新增牌組
    </a>
</div>

@if (!Model.Items.Any())
{
    <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>目前沒有任何字卡牌組。</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>標題</th>
                    <th class="text-center">字卡數</th>
                    <th>建立時間</th>
                    <th style="width:200px">操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var deck in Model.Items)
                {
                    <tr>
                        <td class="text-muted">@deck.Id</td>
                        <td>
                            <a asp-area="Admin" asp-controller="FlashcardDeck" asp-action="Detail" asp-route-id="@deck.Id"
                               class="text-decoration-none fw-semibold">@deck.Title</a>
                        </td>
                        <td class="text-center"><span class="badge bg-info">@deck.CardCount</span></td>
                        <td class="text-muted">@deck.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td>
                            <a asp-area="Admin" asp-controller="FlashcardDeck" asp-action="Edit" asp-route-id="@deck.Id"
                               class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i> 編輯</a>
                            <form asp-area="Admin" asp-controller="FlashcardDeck" asp-action="Delete" asp-route-id="@deck.Id"
                                  method="post" class="d-inline" onsubmit="return confirm('確定要刪除「@deck.Title」嗎？');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> 刪除</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav>
            <ul class="pagination justify-content-center">
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link" asp-area="Admin" asp-controller="FlashcardDeck" asp-action="Index" asp-route-page="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
}

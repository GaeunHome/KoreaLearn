@{ ViewData["Title"] = "找不到頁面"; }

<div class="kl-error-page">
    <div>
        <div class="error-code">404</div>
        <h2 class="mt-3 mb-2">找不到頁面</h2>
        <p class="text-muted mb-4">您所尋找的頁面不存在、已被移除，或者網址有誤。</p>
        <div class="d-flex justify-content-center gap-3">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                <i class="bi bi-house-door me-1"></i>回到首頁
            </a>
            <a asp-controller="Course" asp-action="Index" class="btn btn-outline-primary">
                <i class="bi bi-book me-1"></i>瀏覽課程
            </a>
        </div>
    </div>
</div>

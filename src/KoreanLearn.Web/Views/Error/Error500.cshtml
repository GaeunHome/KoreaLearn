@{ ViewData["Title"] = "系統錯誤"; }

<div class="kl-error-page">
    <div>
        <div class="error-code" style="color: var(--kl-danger);">500</div>
        <h2 class="mt-3 mb-2">系統發生錯誤</h2>
        <p class="text-muted mb-4">抱歉，伺服器遇到了一些問題。<br />請稍後再試，或者聯繫管理員。</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
            <i class="bi bi-house-door me-1"></i>回到首頁
        </a>
    </div>
</div>

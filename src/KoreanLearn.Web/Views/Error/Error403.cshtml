@{ ViewData["Title"] = "沒有權限"; }

<div class="kl-error-page">
    <div>
        <div class="error-code" style="color: var(--kl-warning);">403</div>
        <h2 class="mt-3 mb-2">沒有存取權限</h2>
        <p class="text-muted mb-4">您沒有權限存取此頁面，請確認您已登入正確的帳號。</p>
        <div class="d-flex justify-content-center gap-3">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                <i class="bi bi-house-door me-1"></i>回到首頁
            </a>
            <a asp-area="Identity" asp-controller="Account" asp-action="Login" class="btn btn-outline-primary">
                <i class="bi bi-box-arrow-in-right me-1"></i>重新登入
            </a>
        </div>
    </div>
</div>

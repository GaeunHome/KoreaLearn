@{ ViewData["Title"] = "資料衝突"; }

<div class="kl-error-page">
    <div>
        <div class="error-code" style="color: var(--kl-warning);">409</div>
        <h2 class="mt-3 mb-2">資料已被其他人修改</h2>
        <p class="text-muted mb-4">您正在編輯的資料已被其他使用者更新，請重新整理頁面後再試一次。</p>
        <div class="d-flex justify-content-center gap-3">
            <a href="javascript:location.reload();" class="btn btn-primary">
                <i class="bi bi-arrow-clockwise me-1"></i>重新整理
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">
                <i class="bi bi-house-door me-1"></i>回到首頁
            </a>
        </div>
    </div>
</div>

@model KoreanLearn.Service.ViewModels.Home.HomeViewModel
@{ ViewData["Title"] = "首頁"; }

<!-- Hero Section -->
<div class="p-5 mb-4 bg-primary text-white rounded-3">
    <div class="container-fluid py-3">
        <h1 class="display-5 fw-bold">
            <i class="bi bi-translate me-2"></i>韓文線上學習平台
        </h1>
        <p class="col-md-8 fs-5">從零基礎到流利對話，系統化的韓語課程幫助你循序漸進地掌握韓語。</p>
        <a asp-controller="Course" asp-action="Index" class="btn btn-light btn-lg mt-2">
            <i class="bi bi-book me-1"></i>瀏覽課程
        </a>
    </div>
</div>

<!-- 公告 -->
@if (Model.Announcements.Any())
{
    <div class="mb-4">
        @foreach (var ann in Model.Announcements)
        {
            <div class="alert alert-info">
                <strong><i class="bi bi-megaphone me-1"></i>@ann.Title</strong>
                <span class="ms-2">@ann.Content</span>
                <small class="text-muted ms-2">@ann.CreatedAt.ToString("yyyy/MM/dd")</small>
            </div>
        }
    </div>
}

<!-- 精選課程 -->
<h2 class="mb-3"><i class="bi bi-star me-1"></i>精選課程</h2>

@if (Model.FeaturedCourses.Any())
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var course in Model.FeaturedCourses)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrEmpty(course.CoverImageUrl))
                    {
                        <img src="@course.CoverImageUrl" class="card-img-top" alt="@course.Title"
                             style="height: 200px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="card-img-top bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center"
                             style="height: 200px;">
                            <i class="bi bi-book display-1 text-secondary"></i>
                        </div>
                    }
                    <div class="card-body d-flex flex-column">
                        <div class="mb-2">
                            <span class="badge bg-info">@course.LevelDisplay</span>
                        </div>
                        <h5 class="card-title">@course.Title</h5>
                        <p class="card-text text-muted flex-grow-1">
                            @(course.Description?.Length > 80
                                ? course.Description[..80] + "..."
                                : course.Description)
                        </p>
                        <div class="d-flex justify-content-between align-items-center mt-auto">
                            <span class="h5 text-primary mb-0">NT$ @course.Price.ToString("N0")</span>
                            <a asp-controller="Course" asp-action="Detail" asp-route-id="@course.Id"
                               class="btn btn-outline-primary">查看詳情</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <p class="text-muted text-center py-4">目前沒有已發佈的課程</p>
}

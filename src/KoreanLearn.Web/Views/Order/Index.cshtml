@model KoreanLearn.Library.Helpers.PagedResult<KoreanLearn.Service.Services.Interfaces.OrderListViewModel>
@{ ViewData["Title"] = "我的訂單"; }

<div class="mb-4">
    <h2><i class="bi bi-receipt me-2"></i>我的訂單</h2>
    <p class="text-muted">查看您的購買紀錄與訂單狀態</p>
</div>

@if (!Model.Items.Any())
{
    <div class="card text-center py-5">
        <div class="card-body">
            <i class="bi bi-bag display-1" style="color: var(--kl-border);"></i>
            <h5 class="mt-3">尚無訂單紀錄</h5>
            <p class="text-muted">趕快去看看有哪些韓語課程吧！</p>
            <a asp-controller="Course" asp-action="Index" class="btn btn-primary">
                <i class="bi bi-book me-1"></i>瀏覽課程
            </a>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>訂單編號</th>
                        <th>課程</th>
                        <th class="text-end">金額</th>
                        <th class="text-center">狀態</th>
                        <th>建立日期</th>
                        <th class="text-center">操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model.Items)
                    {
                        <tr>
                            <td><code class="small">@o.OrderNumber</code></td>
                            <td>@(o.CourseName ?? "—")</td>
                            <td class="text-end fw-semibold" style="color: var(--kl-accent);">NT$ @o.TotalAmount.ToString("N0")</td>
                            <td class="text-center">
                                @{
                                    var statusClass = o.Status switch
                                    {
                                        "Completed" => "bg-success",
                                        "Cancelled" => "bg-secondary",
                                        _ => "bg-warning text-dark"
                                    };
                                    var statusText = o.Status switch
                                    {
                                        "Completed" => "已完成",
                                        "Cancelled" => "已取消",
                                        "Pending" => "待付款",
                                        _ => o.Status
                                    };
                                }
                                <span class="badge @statusClass">@statusText</span>
                            </td>
                            <td class="text-muted small">@o.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="text-center">
                                <a asp-controller="Order" asp-action="Detail" asp-route-id="@o.Id"
                                   class="btn btn-sm btn-outline-primary">查看</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

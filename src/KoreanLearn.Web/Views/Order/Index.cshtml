@model KoreanLearn.Library.Helpers.PagedResult<KoreanLearn.Service.Services.Interfaces.OrderListViewModel>
@{ ViewData["Title"] = "我的訂單"; }

<h2 class="mb-4"><i class="bi bi-receipt me-2"></i>我的訂單</h2>

@if (!Model.Items.Any())
{
    <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>您目前沒有任何訂單。</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr><th>訂單編號</th><th>課程</th><th class="text-end">金額</th><th>狀態</th><th>日期</th><th>操作</th></tr>
            </thead>
            <tbody>
                @foreach (var o in Model.Items)
                {
                    <tr>
                        <td><code>@o.OrderNumber</code></td>
                        <td>@(o.CourseName ?? "—")</td>
                        <td class="text-end">NT$ @o.TotalAmount.ToString("N0")</td>
                        <td><span class="badge @(o.Status == "Completed" ? "bg-success" : o.Status == "Cancelled" ? "bg-secondary" : "bg-warning text-dark")">@o.Status</span></td>
                        <td class="text-muted">@o.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td><a asp-controller="Order" asp-action="Detail" asp-route-id="@o.Id" class="btn btn-sm btn-outline-primary">查看</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

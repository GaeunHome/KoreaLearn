@model KoreanLearn.Service.Services.Interfaces.OrderDetailViewModel
@{ ViewData["Title"] = "結帳"; }

<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="text-center mb-4">
            <i class="bi bi-cart-check" style="font-size: 2.5rem; color: var(--kl-primary);"></i>
            <h3 class="mt-2">確認訂單</h3>
            <p class="text-muted">請確認您的購買內容</p>
        </div>

        <div class="card" style="border-radius: var(--kl-radius-lg);">
            <div class="card-body p-4">
                <p class="text-muted small mb-3">訂單編號：<code>@Model.OrderNumber</code></p>

                @foreach (var item in Model.Items)
                {
                    <div class="d-flex justify-content-between align-items-center py-2" style="border-bottom: 1px solid var(--kl-border);">
                        <div>
                            <i class="bi bi-book me-2 text-primary"></i>
                            <span>@item.CourseTitle</span>
                        </div>
                        <span class="fw-semibold">NT$ @item.Price.ToString("N0")</span>
                    </div>
                }

                <div class="d-flex justify-content-between align-items-center pt-3 mt-2">
                    <span class="fw-bold">合計</span>
                    <span class="fw-bold fs-4" style="color: var(--kl-accent);">NT$ @Model.TotalAmount.ToString("N0")</span>
                </div>
            </div>

            <div class="card-footer p-4" style="background: transparent; border-top: 1px solid var(--kl-border);">
                <div class="alert alert-info py-2 mb-3">
                    <i class="bi bi-info-circle me-1"></i>
                    <small>此為模擬付款環境，點擊即完成付款。</small>
                </div>

                <form asp-controller="Order" asp-action="Pay" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success btn-lg w-100"
                            data-confirm="確認付款 NT$ @Model.TotalAmount.ToString("N0") 嗎？">
                        <i class="bi bi-credit-card me-2"></i>確認付款
                    </button>
                </form>
            </div>
        </div>

        <div class="text-center mt-3">
            <a asp-controller="Course" asp-action="Index" class="text-muted small">
                <i class="bi bi-arrow-left me-1"></i>返回課程列表
            </a>
        </div>
    </div>
</div>

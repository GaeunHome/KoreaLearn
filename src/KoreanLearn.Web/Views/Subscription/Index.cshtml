@model IReadOnlyList<KoreanLearn.Service.Services.Interfaces.SubscriptionPlanViewModel>
@{
    ViewData["Title"] = "訂閱方案";
    var currentSub = ViewBag.CurrentSub as KoreanLearn.Service.Services.Interfaces.UserSubscriptionViewModel;
}

<div class="text-center mb-5">
    <h2 style="color: var(--kl-primary-dark);">訂閱方案</h2>
    <p class="text-muted mx-auto" style="max-width: 500px;">
        一次訂閱即可解鎖平台上所有課程，包含字卡練習、發音練習、測驗等完整學習工具。
    </p>
</div>

@if (currentSub is not null)
{
    <div class="alert alert-success text-center mb-4">
        <i class="bi bi-check-circle-fill me-2"></i>
        您目前訂閱：<strong>@currentSub.PlanName</strong>
        （到期：@currentSub.EndDate.ToString("yyyy-MM-dd")，剩餘 @currentSub.RemainingDays 天）
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info text-center">目前沒有可用的訂閱方案。</div>
}
else
{
    <div class="row justify-content-center g-4">
        @for (var i = 0; i < Model.Count; i++)
        {
            var plan = Model[i];
            var isPopular = i == 1;
            <div class="col-md-4">
                <div class="card h-100 text-center @(isPopular ? "border-primary" : "")"
                     style="border-radius: var(--kl-radius-lg); @(isPopular ? "border-width: 2px;" : "")">
                    @if (isPopular)
                    {
                        <div class="py-1 text-white text-center small fw-semibold"
                             style="background: var(--kl-primary); border-radius: var(--kl-radius-lg) var(--kl-radius-lg) 0 0;">
                            最受歡迎
                        </div>
                    }
                    <div class="card-body py-5 px-4">
                        <h5 class="card-title mb-1">@plan.Name</h5>
                        <p class="text-muted small">@plan.DurationMonths 個月</p>
                        @if (!string.IsNullOrEmpty(plan.Description))
                        {
                            <p class="text-muted small mb-4">@plan.Description</p>
                        }
                        <div class="mb-1">
                            <span class="fw-bold" style="font-size: 2.5rem; color: var(--kl-primary-dark);">
                                NT$ @plan.MonthlyPrice.ToString("N0")
                            </span>
                        </div>
                        <p class="text-muted small">每月</p>

                        <ul class="list-unstyled text-start mt-4 mb-0 small">
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>所有課程無限觀看</li>
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>字卡與發音練習</li>
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>測驗與結業證書</li>
                            <li><i class="bi bi-check-circle-fill text-success me-2"></i>討論區完整功能</li>
                        </ul>
                    </div>
                    <div class="card-footer py-3 px-4" style="background: transparent; border-top: 1px solid var(--kl-border);">
                        @if (currentSub is not null)
                        {
                            <button class="btn btn-secondary w-100" disabled>已訂閱</button>
                        }
                        else if (User.Identity?.IsAuthenticated == true)
                        {
                            <form asp-controller="Subscription" asp-action="Subscribe" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="planId" value="@plan.Id" />
                                <button type="submit"
                                        class="btn @(isPopular ? "btn-primary" : "btn-outline-primary") w-100"
                                        data-confirm="確定要訂閱「@plan.Name」嗎？（NT$ @(plan.MonthlyPrice * plan.DurationMonths) / @plan.DurationMonths 個月）">
                                    立即訂閱
                                </button>
                            </form>
                        }
                        else
                        {
                            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-primary w-100">登入後訂閱</a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

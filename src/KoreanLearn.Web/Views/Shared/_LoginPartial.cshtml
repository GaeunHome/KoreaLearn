@using Microsoft.AspNetCore.Identity
@using KoreanLearn.Data.Entities
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <ul class="navbar-nav">
        @if (User.IsInRole("Admin"))
        {
            <li class="nav-item">
                <a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-gear"></i> 後台管理
                </a>
            </li>
        }
        <li class="nav-item">
            <a class="nav-link" asp-area="Learn" asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-mortarboard"></i> 我的學習
            </a>
        </li>
        <li class="nav-item">
            <span class="nav-link text-light">
                <i class="bi bi-person-circle"></i> @UserManager.GetUserName(User)
            </span>
        </li>
        <li class="nav-item">
            <form asp-area="Identity" asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
                  method="post" class="d-inline">
                <button type="submit" class="nav-link btn btn-link text-white">
                    <i class="bi bi-box-arrow-right"></i> 登出
                </button>
            </form>
        </li>
    </ul>
}
else
{
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">
                <i class="bi bi-person"></i> 登入
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-area="Identity" asp-page="/Account/Register">
                <i class="bi bi-person-plus"></i> 註冊
            </a>
        </li>
    </ul>
}

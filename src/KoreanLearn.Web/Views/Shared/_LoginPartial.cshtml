@using KoreanLearn.Service.Services.Interfaces
@inject IAuthService AuthService

@if (AuthService.IsSignedIn(User))
{
    <ul class="navbar-nav">
        @if (AuthService.IsInRole(User, "Admin"))
        {
            <li class="nav-item">
                <a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-gear"></i> 後台管理
                </a>
            </li>
        }
        @if (AuthService.IsInRole(User, "Teacher"))
        {
            <li class="nav-item">
                <a class="nav-link" asp-area="Teacher" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-person-workspace"></i> 教師管理
                </a>
            </li>
        }
        <li class="nav-item">
            <a class="nav-link" asp-area="Learn" asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-mortarboard"></i> 我的學習
            </a>
        </li>
        <li class="nav-item">
            <span class="nav-link text-light">
                <i class="bi bi-person-circle"></i> @AuthService.GetUserName(User)
            </span>
        </li>
        <li class="nav-item d-flex align-items-center">
            <form asp-area="Identity" asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
                  method="post" class="mb-0">
                <button type="submit" class="nav-link border-0 bg-transparent text-white px-2">
                    <i class="bi bi-box-arrow-right"></i> 登出
                </button>
            </form>
        </li>
    </ul>
}
else
{
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">
                <i class="bi bi-person"></i> 登入
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-area="Identity" asp-page="/Account/Register">
                <i class="bi bi-person-plus"></i> 註冊
            </a>
        </li>
    </ul>
}

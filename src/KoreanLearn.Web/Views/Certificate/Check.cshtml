@model KoreanLearn.Service.Services.Interfaces.CertificateEligibility
@{ ViewData["Title"] = "結業證書"; var courseId = (int)ViewBag.CourseId; }

<div class="row justify-content-center py-4">
    <div class="col-lg-5">
        @if (Model.IsEligible)
        {
            <div class="card text-center" style="border-radius: var(--kl-radius-lg);">
                <div class="card-body py-5 px-4">
                    <div class="mb-3">
                        <i class="bi bi-award-fill" style="font-size: 4rem; color: var(--kl-warning);"></i>
                    </div>
                    <h3 style="color: var(--kl-success);">恭喜完成課程！</h3>
                    <p class="text-muted mt-2">
                        你已完成 @Model.CompletedLessons / @Model.TotalLessons 堂課
                    </p>
                    @if (Model.QuizScore.HasValue)
                    {
                        <p class="text-muted">
                            測驗最佳成績：<strong>@Model.QuizScore 分</strong>（及格：@Model.PassingScore 分）
                        </p>
                    }
                    <a asp-controller="Certificate" asp-action="Download" asp-route-courseId="@courseId"
                       class="btn btn-warning btn-lg mt-3">
                        <i class="bi bi-download me-2"></i>下載證書 PDF
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="card text-center" style="border-radius: var(--kl-radius-lg);">
                <div class="card-body py-5 px-4">
                    <div class="mb-3">
                        <i class="bi bi-lock" style="font-size: 3.5rem; color: var(--kl-border);"></i>
                    </div>
                    <h4>尚未符合取得條件</h4>
                    <p class="text-danger small mt-2">@Model.Reason</p>

                    <div class="mx-auto my-4" style="max-width: 280px;">
                        <div class="d-flex justify-content-between small text-muted mb-1">
                            <span>學習進度</span>
                            <span>@Model.CompletedLessons / @Model.TotalLessons</span>
                        </div>
                        <div class="progress" style="height: 8px;">
                            <div class="progress-bar bg-primary"
                                 style="width: @(Model.TotalLessons > 0 ? Model.CompletedLessons * 100 / Model.TotalLessons : 0)%"></div>
                        </div>
                    </div>

                    <a asp-controller="Course" asp-action="Detail" asp-route-id="@courseId"
                       class="btn btn-primary">
                        <i class="bi bi-arrow-left me-1"></i>繼續學習
                    </a>
                </div>
            </div>
        }
    </div>
</div>

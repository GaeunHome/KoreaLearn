@model KoreanLearn.Service.Services.Interfaces.CertificateEligibility
@{ ViewData["Title"] = "證書"; var courseId = (int)ViewBag.CourseId; }

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow-sm text-center py-5">
            @if (Model.IsEligible)
            {
                <div class="card-body">
                    <i class="bi bi-award-fill display-1 text-warning"></i>
                    <h3 class="mt-3 text-success">恭喜！您已符合證書取得條件</h3>
                    <p class="text-muted">完成 @Model.CompletedLessons / @Model.TotalLessons 堂課</p>
                    @if (Model.QuizScore.HasValue)
                    {
                        <p class="text-muted">測驗最佳成績：@Model.QuizScore 分（及格：@Model.PassingScore 分）</p>
                    }
                    <a asp-controller="Certificate" asp-action="Download" asp-route-courseId="@courseId"
                       class="btn btn-warning btn-lg mt-3">
                        <i class="bi bi-download me-2"></i>下載證書 PDF
                    </a>
                </div>
            }
            else
            {
                <div class="card-body">
                    <i class="bi bi-lock-fill display-1 text-secondary"></i>
                    <h3 class="mt-3">尚未符合條件</h3>
                    <p class="text-danger">@Model.Reason</p>
                    <div class="progress mx-auto mb-3" style="max-width:300px; height:10px;">
                        <div class="progress-bar" style="width:@(Model.TotalLessons > 0 ? Model.CompletedLessons * 100 / Model.TotalLessons : 0)%"></div>
                    </div>
                    <p class="text-muted">已完成 @Model.CompletedLessons / @Model.TotalLessons 堂課</p>
                    <a asp-controller="Course" asp-action="Detail" asp-route-id="@courseId"
                       class="btn btn-primary mt-2">
                        <i class="bi bi-arrow-left me-1"></i>返回課程繼續學習
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@model KoreanLearn.Library.Helpers.PagedResult<KoreanLearn.Service.ViewModels.Course.CourseListViewModel>
@{ ViewData["Title"] = "課程列表"; }

<div class="mb-4">
    <h2 class="mb-1"><i class="bi bi-book me-2"></i>課程列表</h2>
    <p class="text-muted">探索我們的韓語課程，找到最適合你的學習計畫</p>
</div>

<form method="get" class="mb-4">
    <div class="input-group" style="max-width: 420px;">
        <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control"
               placeholder="搜尋課程名稱..." />
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-search"></i> 搜尋
        </button>
        @if (!string.IsNullOrEmpty(ViewBag.Keyword as string))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">清除</a>
        }
    </div>
</form>

@if (Model.Items.Any())
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var course in Model.Items)
        {
            <div class="col">
                <div class="kl-course-card card h-100">
                    @if (!string.IsNullOrEmpty(course.CoverImageUrl))
                    {
                        <img src="@course.CoverImageUrl" class="card-img-top" alt="@course.Title" />
                    }
                    else
                    {
                        <div class="card-img-top d-flex align-items-center justify-content-center"
                             style="height: 180px; background: linear-gradient(135deg, #EEF1F7 0%, #E1E6EF 100%);">
                            <i class="bi bi-book display-3" style="color: var(--kl-primary); opacity: 0.25;"></i>
                        </div>
                    }
                    <div class="card-body d-flex flex-column">
                        <div class="mb-2">
                            <span class="badge bg-info">@course.LevelDisplay</span>
                            @if (course.SectionCount > 0)
                            {
                                <span class="badge bg-secondary ms-1">@course.SectionCount 章</span>
                            }
                        </div>
                        <h5 class="card-title" style="font-size: 1.05rem;">@course.Title</h5>
                        <p class="card-text text-muted small flex-grow-1">
                            @if (course.Description?.Length > 100)
                            {
                                @course.Description[..100]<text>...</text>
                            }
                            else
                            {
                                @course.Description
                            }
                        </p>
                        <div class="d-flex justify-content-between align-items-center mt-auto pt-2"
                             style="border-top: 1px solid var(--kl-border);">
                            <span class="fw-bold" style="color: var(--kl-accent);">NT$ @course.Price.ToString("N0")</span>
                            <a asp-action="Detail" asp-route-id="@course.Id"
                               class="btn btn-sm btn-primary">查看詳情</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4" aria-label="分頁">
            <ul class="pagination justify-content-center">
                @if (Model.HasPrevious)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@(Model.Page - 1)" asp-route-keyword="@ViewBag.Keyword">上一頁</a>
                    </li>
                }
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@i" asp-route-keyword="@ViewBag.Keyword">@i</a>
                    </li>
                }
                @if (Model.HasNext)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@(Model.Page + 1)" asp-route-keyword="@ViewBag.Keyword">下一頁</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
else
{
    <div class="text-center py-5">
        <i class="bi bi-search display-1 text-muted"></i>
        <p class="text-muted mt-3">
            @if (!string.IsNullOrEmpty(ViewBag.Keyword as string))
            {
                @:找不到符合「@ViewBag.Keyword」的課程
            }
            else
            {
                @:目前沒有已發佈的課程
            }
        </p>
    </div>
}

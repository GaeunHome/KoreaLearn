@model KoreanLearn.Service.ViewModels.Course.CourseDetailViewModel
@using KoreanLearn.Library.Enums
@{ ViewData["Title"] = Model.Title; }

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">首頁</a></li>
        <li class="breadcrumb-item"><a asp-controller="Course" asp-action="Index">課程列表</a></li>
        <li class="breadcrumb-item active">@Model.Title</li>
    </ol>
</nav>

<div class="row">
    <!-- 課程資訊 -->
    <div class="col-md-8">
        <h1 class="h2 mb-2">@Model.Title</h1>
        <div class="mb-3">
            <span class="badge bg-info fs-6">@Model.LevelDisplay</span>
            <span class="text-muted ms-2">@Model.TotalLessons 堂課</span>
            <span class="text-muted ms-2">@Model.Sections.Count 章節</span>
            @if (!string.IsNullOrEmpty(Model.TeacherName))
            {
                <span class="text-muted ms-2"><i class="bi bi-person-badge me-1"></i>@Model.TeacherName</span>
            }
        </div>

        @if (Model.IsEnrolled && Model.CompletedLessons > 0)
        {
            <div class="card mb-4 border-success">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="mb-0"><i class="bi bi-graph-up me-1"></i>學習進度</h6>
                        <span class="fw-bold text-success">@Model.ProgressPercent%</span>
                    </div>
                    <div class="progress" style="height: 10px;">
                        <div class="progress-bar bg-success" role="progressbar"
                             style="width: @Model.ProgressPercent%" aria-valuenow="@Model.ProgressPercent"
                             aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <small class="text-muted mt-1 d-block">@Model.CompletedLessons / @Model.TotalLessons 堂已完成</small>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="card mb-4">
                <div class="card-body">
                    <h5 class="card-title">課程介紹</h5>
                    <p class="card-text">@Model.Description</p>
                </div>
            </div>
        }

        <!-- 課程大綱 -->
        <h3 class="h4 mb-3"><i class="bi bi-list-ol me-1"></i>課程大綱</h3>

        @if (Model.Sections.Any())
        {
            <div class="accordion" id="courseOutline">
                @for (int i = 0; i < Model.Sections.Count; i++)
                {
                    var sec = Model.Sections[i];
                    var collapseId = $"section{sec.Id}";
                    var completedInSection = sec.Lessons.Count(l => l.IsCompleted);
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button @(i > 0 ? "collapsed" : "")" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#@collapseId">
                                <strong>@sec.Title</strong>
                                <span class="badge bg-secondary ms-2">@sec.Lessons.Count 堂</span>
                                @if (completedInSection > 0)
                                {
                                    <span class="badge bg-success ms-1">@completedInSection 已完成</span>
                                }
                            </button>
                        </h2>
                        <div id="@collapseId" class="accordion-collapse collapse @(i == 0 ? "show" : "")"
                             data-bs-parent="#courseOutline">
                            <div class="accordion-body p-0">
                                <ul class="list-group list-group-flush">
                                    @foreach (var lesson in sec.Lessons)
                                    {
                                        var lessonAction = lesson.Type switch
                                        {
                                            LessonType.Video => "Video",
                                            LessonType.Article => "Article",
                                            LessonType.Pdf => "Pdf",
                                            _ => "Article"
                                        };
                                        var canAccess = Model.IsEnrolled || lesson.IsFreePreview;
                                        <li class="list-group-item d-flex justify-content-between align-items-center">
                                            <span>
                                                @if (Model.IsEnrolled && lesson.IsCompleted)
                                                {
                                                    <i class="bi bi-check-circle-fill me-2 text-success"></i>
                                                }
                                                else if (canAccess)
                                                {
                                                    <i class="bi @lesson.TypeIcon me-2 text-muted"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-lock me-2 text-muted"></i>
                                                }
                                                @if (canAccess && User.Identity?.IsAuthenticated == true)
                                                {
                                                    <a asp-area="Learn" asp-controller="Lesson" asp-action="@lessonAction" asp-route-id="@lesson.Id"
                                                       class="text-decoration-none">
                                                        @lesson.Title
                                                    </a>
                                                }
                                                else
                                                {
                                                    <span class="@(!canAccess ? "text-muted" : "")">@lesson.Title</span>
                                                }
                                                @if (lesson.IsFreePreview)
                                                {
                                                    <span class="badge bg-success ms-1">免費試看</span>
                                                }
                                            </span>
                                            <span class="badge bg-light text-dark">@lesson.TypeDisplay</span>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-muted">此課程尚無章節內容</p>
        }
    </div>

    <!-- 側邊欄：購買資訊 -->
    <div class="col-md-4">
        <div class="card shadow-sm sticky-top" style="top: 20px;">
            @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
            {
                <img src="@Model.CoverImageUrl" class="card-img-top" alt="@Model.Title" />
            }
            else
            {
                <div class="card-img-top d-flex align-items-center justify-content-center"
                     style="height: 200px; background: linear-gradient(135deg, #EEF1F7 0%, #E1E6EF 100%);">
                    <i class="bi bi-book display-1" style="color: var(--kl-primary); opacity: 0.2;"></i>
                </div>
            }
            <div class="card-body text-center">
                @if (Model.IsEnrolled)
                {
                    <!-- 已購買：顯示繼續學習 -->
                    <div class="mb-3">
                        <span class="badge bg-success fs-6 px-3 py-2">
                            <i class="bi bi-check-circle me-1"></i>已購買
                        </span>
                    </div>
                    @if (Model.TotalLessons > 0)
                    {
                        var firstIncomplete = Model.Sections
                                .SelectMany(s => s.Lessons)
                                .FirstOrDefault(l => !l.IsCompleted);
                            var targetLesson = firstIncomplete ?? Model.Sections.First().Lessons.First();
                            var targetAction = targetLesson.Type switch
                            {
                                LessonType.Video => "Video",
                                LessonType.Article => "Article",
                                LessonType.Pdf => "Pdf",
                                _ => "Article"
                            };
                        <a asp-area="Learn" asp-controller="Lesson" asp-action="@targetAction" asp-route-id="@targetLesson.Id"
                           class="btn btn-primary btn-lg w-100 mb-2">
                            <i class="bi bi-play-circle me-1"></i>
                            @(firstIncomplete is not null ? "繼續學習" : "複習課程")
                        </a>
                    }
                    <a asp-area="Learn" asp-controller="Dashboard" asp-action="Index"
                       class="btn btn-outline-primary btn-sm w-100">
                        <i class="bi bi-mortarboard me-1"></i>我的學習
                    </a>
                }
                else if (User.Identity?.IsAuthenticated == true)
                {
                    <!-- 已登入未購買：顯示價格 + 購買 -->
                    <h4 class="mb-3" style="color: var(--kl-accent);">NT$ @Model.Price.ToString("N0")</h4>
                    <form asp-controller="Order" asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="courseId" value="@Model.Id" />
                        <button type="submit" class="btn btn-primary btn-lg w-100 mb-2"
                                data-confirm="確定要購買「@Model.Title」（NT$ @Model.Price.ToString("N0")）嗎？">
                            <i class="bi bi-cart-plus me-1"></i>立即購買
                        </button>
                    </form>
                    <p class="text-muted small mt-2 mb-0">
                        <i class="bi bi-shield-check me-1"></i>購買後即可永久觀看
                    </p>
                }
                else
                {
                    <!-- 未登入：顯示價格 + 登入 -->
                    <h4 class="mb-3" style="color: var(--kl-accent);">NT$ @Model.Price.ToString("N0")</h4>
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-lg w-100 mb-2">
                        <i class="bi bi-box-arrow-in-right me-1"></i>登入後購買
                    </a>
                    <p class="text-muted small mt-2 mb-0">
                        <i class="bi bi-shield-check me-1"></i>購買後即可永久觀看
                    </p>
                }
            </div>
        </div>
    </div>
</div>

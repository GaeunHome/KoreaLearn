@{
    ViewData["Title"] = "選擇課程";
    var courses = ViewBag.Courses as IReadOnlyList<KoreanLearn.Service.ViewModels.Course.CourseListViewModel>;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Discussion" asp-action="Index">討論區</a></li>
        <li class="breadcrumb-item active">選擇課程</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-body p-4">
                <h4 class="mb-3"><i class="bi bi-book me-2"></i>請選擇要討論的課程</h4>
                <p class="text-muted mb-4">每則討論都會歸屬在一門課程底下，請先選擇課程。</p>

                @if (courses is not null && courses.Any())
                {
                    <div class="list-group">
                        @foreach (var c in courses)
                        {
                            <a asp-controller="Discussion" asp-action="Create" asp-route-courseId="@c.Id"
                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center p-3">
                                <div>
                                    <h6 class="mb-0">@c.Title</h6>
                                    <small class="text-muted">@c.LevelDisplay</small>
                                </div>
                                <i class="bi bi-chevron-right text-muted"></i>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-inbox display-4"></i>
                        <p class="mt-2">目前沒有可用的課程。</p>
                    </div>
                }

                <div class="mt-3">
                    <a asp-controller="Discussion" asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>返回討論區
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@model KoreanLearn.Library.Helpers.PagedResult<KoreanLearn.Service.Services.Interfaces.DiscussionListItem>
@{ ViewData["Title"] = "討論區"; var courseId = ViewBag.CourseId as int?; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2><i class="bi bi-chat-dots me-2"></i>討論區</h2>
        <p class="text-muted mb-0">和其他同學交流學習心得</p>
    </div>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-controller="Discussion" asp-action="Create"
           asp-route-courseId="@courseId" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>發起討論
        </a>
    }
    else
    {
        <button class="btn btn-primary" data-require-auth>
            <i class="bi bi-plus-lg me-1"></i>發起討論
        </button>
    }
</div>

@if (!Model.Items.Any())
{
    <div class="card text-center py-5">
        <div class="card-body">
            <i class="bi bi-chat display-1" style="color: var(--kl-border);"></i>
            <h5 class="mt-3">目前還沒有討論</h5>
            <p class="text-muted">成為第一個發起討論的人吧！</p>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="list-group list-group-flush">
            @foreach (var d in Model.Items)
            {
                <a asp-controller="Discussion" asp-action="Detail" asp-route-id="@d.Id"
                   class="list-group-item list-group-item-action p-3">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="mb-1">@d.Title</h6>
                            <small class="text-muted">
                                <i class="bi bi-person me-1"></i>@d.AuthorName
                                @if (!string.IsNullOrEmpty(d.CourseName))
                                {
                                    <span class="mx-1">·</span>
                                    <i class="bi bi-book me-1"></i>@d.CourseName
                                }
                                <span class="mx-1">·</span>
                                <i class="bi bi-chat me-1"></i>@d.ReplyCount 則回覆
                            </small>
                        </div>
                        <small class="text-muted">@d.CreatedAt.ToString("MM/dd")</small>
                    </div>
                </a>
            }
        </div>
    </div>
}

<div class="mt-3">
    @if (courseId.HasValue && courseId.Value > 0)
    {
        <a asp-controller="Course" asp-action="Detail" asp-route-id="@courseId" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>返回課程
        </a>
    }
    else
    {
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>返回首頁
        </a>
    }
</div>

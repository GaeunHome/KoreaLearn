@model KoreanLearn.Service.Services.Interfaces.DiscussionDetailViewModel
@{ ViewData["Title"] = Model.Title; }

<div class="mb-3">
    <a asp-controller="Discussion" asp-action="Index" asp-route-courseId="@Model.CourseId" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>返回討論區
    </a>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h3>@Model.Title</h3>
        <p class="text-muted small">@Model.AuthorName · @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</p>
        <p>@Model.Content</p>
    </div>
</div>

<h5 class="mb-3"><i class="bi bi-chat me-1"></i>回覆 (@Model.Replies.Count)</h5>

@foreach (var r in Model.Replies)
{
    <div class="card mb-2">
        <div class="card-body py-2">
            <p class="mb-1">@r.Content</p>
            <small class="text-muted">@r.AuthorName · @r.CreatedAt.ToString("yyyy-MM-dd HH:mm")</small>
        </div>
    </div>
}

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="card mt-3">
        <div class="card-body">
            <form asp-controller="Discussion" asp-action="Reply" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="discussionId" value="@Model.Id" />
                <div class="mb-2">
                    <textarea name="content" class="form-control" rows="3" placeholder="輸入回覆..." required></textarea>
                </div>
                <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-reply me-1"></i>回覆</button>
            </form>
        </div>
    </div>
}

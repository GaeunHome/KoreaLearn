@model KoreanLearn.Service.ViewModels.Announcement.AnnouncementDetailViewModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <!-- Header -->
                    <div class="mb-3">
                        <small class="text-muted">
                            <i class="bi bi-calendar3 me-1"></i>@Model.CreatedAt.ToString("yyyy 年 MM 月 dd 日 HH:mm")
                        </small>
                        @if (Model.IsPinned)
                        {
                            <span class="badge bg-warning text-dark ms-2">
                                <i class="bi bi-pin-angle-fill me-1"></i>置頂
                            </span>
                        }
                    </div>

                    <h3 class="mb-4">@Model.Title</h3>

                    <!-- Content -->
                    <div class="mb-4" style="line-height: 1.8;">
                        @Html.Raw(Model.Content.Replace("\n", "<br />"))
                    </div>

                    <!-- Attachments -->
                    @if (Model.Attachments.Any())
                    {
                        <hr />
                        <h6 class="mb-3"><i class="bi bi-paperclip me-1"></i>附件 (@Model.Attachments.Count)</h6>
                        <div class="list-group">
                            @foreach (var att in Model.Attachments)
                            {
                                <a href="@att.FileUrl" target="_blank" download
                                   class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                    <span>
                                        <i class="bi bi-file-earmark me-2"></i>@att.FileName
                                    </span>
                                    <span class="badge bg-light text-dark">@att.FileSizeDisplay</span>
                                </a>
                            }
                        </div>
                    }
                </div>

                <div class="card-footer text-center py-3">
                    <a asp-action="Index" class="text-decoration-none">
                        <i class="bi bi-arrow-left me-1"></i>返回公告列表
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
